# Containerfile.fedora — llama-rocmfpx-strix on Fedora 43
#
# Why Fedora 43 (not Ubuntu)?
#   The working host M5 build was done on Fedora 43 with:
#     - clang 21.1.8, LLVM 21.1.8, meson 1.8.5
#     - Mesa 26.1.3 source build, RADV + wayland only
#     - ROCm 7.2.2 (from AMD's official tarball, not Fedora's dnf rocm-* packages)
#     - ciru-ai/ROCmFPX at main, ~140 tok/s on Qwen3.5-27B Q4_K_M
#   Fedora 43 in a container is the closest thing to the working host.
#   For Ubuntu, see Containerfile.ubuntu.
#
# Post-mortem (why this took 5 builds, not 1):
#   - Knowledge/post-mortems/2026-06-26-fedora-base-package-name-fixes.md
#   - Knowledge/post-mortems/2026-06-26-container-polly-link-error-and-strategy-pivot.md
#
# Build:
#   podman build -t llama-rocmfpx-strix:fedora-43 -f Containerfile.fedora .
#
# Run:
#   podman run --rm --device /dev/dri --group-add keep-groups \
#     --security-opt seccomp=unconfined \
#     -v ~/.cache/huggingface:/root/.cache/huggingface \
#     -p 8080:8080 \
#     llama-rocmfpx-strix:fedora-43 \
#     --model <model.gguf> --port 8080

FROM fedora:43

ARG MESA_TAG=mesa-26.1.3
ARG ROCMFPX_REF=main
ARG ROCM_VERSION=7.2.2
ARG CCACHE_DIR=/ccache

ENV LANG=C.UTF-8 \
    LC_ALL=C.UTF-8 \
    ROCM_PATH=/usr \
    HIP_PATH=/usr \
    PATH=/usr/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin \
    LD_LIBRARY_PATH=/usr/lib64:/usr/local/lib64 \
    CCACHE_DIR=/ccache

# ----------------------------------------------------------------------------
# Step 1: AMD ROCm 7.2.2 official repo (el10 path serves Fedora 43)
# ----------------------------------------------------------------------------
# AMD's official naming: "el8", "el9", "el10" for RHEL major versions.
# Fedora 43 ~= RHEL 10, so we use el10. The repo file is dynamically generated
# by their installer, so we write it directly with the static baseurl. This
# brings in:
#   - rocm-hip-devel    (ROCm headers + hipcc)
#   - rocm-hip          (libamdhip64.so for runtime)
#   - rocm-opencl       (libhsa-runtime64.so)
#   - rocm-comgr        (compiler runtime)
#   - rocm-llvm         (LLVM for kernel compilation)
#   - hipblas, rocblas  (BLAS, transitive deps)
# ----------------------------------------------------------------------------
RUN cat > /etc/yum.repos.d/rocm.repo <<'EOF'
[ROCm-7.2.2]
name=ROCm 7.2.2 (el10)
baseurl=https://repo.radeon.com/rocm/el10/7.2.2/main
enabled=1
gpgcheck=1
gpgkey=https://repo.radeon.com/rocm/rocm.gpg.key

[amdgpu]
name=amdgpu (el10)
baseurl=https://repo.radeon.com/amdgpu/latest/el10/main
enabled=1
gpgcheck=1
gpgkey=https://repo.radeon.com/rocm/rocm.gpg.key
EOF

RUN dnf install -y --setopt=install_weak_deps=False --best \
        # --- Compiler + build tools ---
        clang llvm llvm-devel llvm-libs lld \
        meson ninja-build ccache mold \
        cmake gcc gcc-c++ make \
        python3 python3-pip python3-devel python3-mako python3-pyyaml \
        # --- Mesa source build deps (Fedora 43 package names) ---
        # NOTE: Fedora names differ from Ubuntu:
        #   libelf-devel    -> elfutils-libelf-devel
        #   libwayland-devel -> wayland-devel
        #   zstd-devel      -> libzstd-devel
        libdrm-devel elfutils-libelf-devel wayland-devel \
        libxshmfence-devel libXext-devel libXfixes-devel \
        glslang spirv-tools \
        bison flex \
        expat-devel zlib-devel libzstd-devel libxml2-devel \
        # --- ROCm 7.2.2 (from the rocm.repo we just wrote; these are AMD's
        #     actual package names on el10, NOT Fedora's rocm-runtime 6.4.2
        #     names. Key swaps vs Ubuntu's rocm/dev image: hip-devel not
        #     rocm-hip-devel, comgr not rocm-comgr.)
        hip-devel hipcc hip-runtime-amd \
        rocblas-devel hipblas-devel \
        comgr rocm-llvm rocm-opencl \
        hsa-rocr hsa-rocr-devel \
        # --- Misc ---
        git wget curl ca-certificates tar bash \
    && dnf clean all \
    && rm -rf /var/cache/dnf

# ----------------------------------------------------------------------------
# Step 2: Mesa 26.1.3 source build + install to /opt/mesa-26.1.3
# ----------------------------------------------------------------------------
# Flags mirror the working host (~/mesa-26.1.3/build/meson-logs/meson-log.txt).
# The Fedora host's build used clang 21 + LLVM 21 + meson 1.8.5. We match that.
# ----------------------------------------------------------------------------
WORKDIR /opt/src
RUN git clone --depth 1 --branch ${MESA_TAG} https://gitlab.freedesktop.org/mesa/mesa.git mesa-${MESA_TAG} \
    && cd mesa-${MESA_TAG} \
    && CC=clang CXX=clang++ \
       meson setup build --prefix=/opt/mesa-26.1.3 \
        -Dvulkan-drivers=amd \
        -Dgallium-drivers=radeonsi \
        -Dplatforms=wayland \
        -Dllvm=enabled \
        -Degl=disabled -Dglx=disabled \
        -Dgbm=disabled \
        -Dlibunwind=disabled -Dvalgrind=disabled \
        -Dbuildtype=release \
    && meson compile -C build \
    && meson install -C build \
    && cd / && rm -rf /opt/src/mesa-${MESA_TAG} /opt/src/mesa-${MESA_TAG}/build

# ----------------------------------------------------------------------------
# Step 3: ciru-ai/ROCmFPX (the engine) source build + install to /usr/local
# ----------------------------------------------------------------------------
# Uses CMake flags that mirror the working host's
# ~/ROCmFPX/build-strix-rocmfp4/CMakeCache.txt. Vulkan is the runtime backend
# (HIP is statically compiled-in but not used for inference on this setup;
# GGML_HIP_GRAPH paths matter for kernel pipeline even under Vulkan).
# ----------------------------------------------------------------------------
WORKDIR /opt/src
RUN git clone --depth 1 --branch ${ROCMFPX_REF} https://github.com/ciru-ai/ROCmFPX.git ROCmFPX \
    && cd ROCmFPX \
    && CC=clang CXX=clang++ \
       cmake -S . -B build -G Ninja \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr/local \
        -DGGML_HIP=ON \
        -DGGML_VULKAN=ON \
        -DGGML_CPU=OFF \
        -DGGML_BLAS=OFF \
        -DGGML_CUDA=OFF \
        -DGGML_METAL=OFF \
        -DGGML_OPENCL=OFF \
        -DAMDGPU_TARGETS=gfx1151 \
    && cmake --build build --target install -j$(nproc) \
    && cd / && rm -rf /opt/src/ROCmFPX /opt/src/ROCmFPX/build

# ----------------------------------------------------------------------------
# Step 4: Final cleanup
# ----------------------------------------------------------------------------
# Remove the Mesa+ROCmFPX build sources (we kept the installs at /opt and
# /usr/local). Drop dnf cache and ccache dir to keep image small.
# ----------------------------------------------------------------------------
RUN dnf clean all \
    && rm -rf /var/cache/dnf /var/cache/yum /ccache

# ----------------------------------------------------------------------------
# Entrypoint
# ----------------------------------------------------------------------------
COPY entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

WORKDIR /root
ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
CMD ["--help"]

# Image size: ~1.5 GB (Fedora 43 base ~500MB + Mesa ~200MB + ROCm ~500MB + ROCmFPX ~150MB)
